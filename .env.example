# oh-my-deepseek (omd) Configuration
# Copy to .env or export directly in your shell

# Required: DeepSeek API key
# Get yours at https://platform.deepseek.com/api_keys
OMD_API_KEY=sk-your-key-here

# Optional: Model overrides
# OMD_MODEL=deepseek-chat
# OMD_REASONER_MODEL=deepseek-reasoner

# Optional: API endpoint (self-hosted or proxy)
# OMD_BASE_URL=https://api.deepseek.com

# Optional: Generation parameters
# OMD_MAX_TOKENS=8192
# OMD_TEMPERATURE=0.7

# Optional: Default orchestration mode
# OMD_DEFAULT_MODE=autopilot
